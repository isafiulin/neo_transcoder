{
  "server": {
    "bind": "0.0.0.0",
    "port": 8080
  },
  "ffmpeg": {
    "path": "/usr/bin/ffmpeg",
    "ffprobe_path": "/usr/bin/ffprobe",
    "log_level": "warning",
    "udp": {
      "buffer_size": 8388608,
      "fifo_size": 100000000,
      "overrun_nonfatal": true,
      "reuse": true,
      "pkt_size": 1316
    },
    "probe": {
      "analyzeduration": 10000000,
      "probesize": 20000000
    }
  },
  "storage": {
    "path": "/var/lib/neotranscoder/state.json"
  },
  "logs": {
    "level": "info",
    "path": "/var/log/neotranscoder/neotranscoder.log"
  }
}
